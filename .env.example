# Public site URL (used for metadata).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Neon: pooled URL (host contains "-pooler"). Same USER:PASSWORD as DIRECT_URL.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"

# Neon: direct URL (Connect → turn Connection pooling OFF). Used for prisma migrate / seed.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"

CRON_SECRET=

# SerpApi — Google Shopping + Google Immersive Product (server-side cron only; never per page view).
# https://serpapi.com/google-shopping-api
# https://serpapi.com/google-immersive-product-api
SERPAPI_API_KEY=

# Localization for Shopping / Immersive (US English defaults).
# SERPAPI_GL=us
# SERPAPI_HL=en

# Hard cap on billable SerpApi requests per cron run (shopping + immersive each count as 1).
# ~8/day × 30 ≈ 240/mo — tune to your SerpApi plan (cached repeats are free for 1h).
# SERPAPI_MAX_CALLS_PER_RUN=8

# Listing quality (Amazon / Best Buy / Walmart only). Optional tuning 0.35–0.75 / 1.2–3 / 0.25–0.55.
# LISTING_PRICE_MIN_TO_MEDIAN_RATIO=0.52
# LISTING_TWO_STORE_SPREAD_RATIO=1.65
# LISTING_TWO_STORE_LOW_VS_HIGH=0.42

# When immersive results omit Amazon: Google Shopping (… + amazon.com), then SerpApi engine=amazon for a real /dp/ URL.
# SERPAPI_AMAZON_FALLBACK=0 disables both. SERPAPI_AMAZON_ENGINE=0 skips only the Amazon Search step (after Shopping).
# SERPAPI_AMAZON_FALLBACK=1
# SERPAPI_AMAZON_ENGINE=1

# Amazon Associates tag appended to Amazon outbound links on product pages (e.g. yoursite-20).
# AMAZON_ASSOCIATES_TAG=yoursite-20
# AMAZON_DOMAIN=amazon.com

# One-time: wipes Product, ProductStoreListing, PriceSnapshot only (posts kept). Remove after one deploy.
# RESET_CATALOG_ON_SEED=1

