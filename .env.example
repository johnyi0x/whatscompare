# Public site URL (used for metadata).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Neon: pooled URL (host contains "-pooler"). Same USER:PASSWORD as DIRECT_URL.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"

# Neon: direct URL (Connect → turn Connection pooling OFF). Used for prisma migrate / seed.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"

CRON_SECRET=

# Claude — catalog cron only (enrichment uses web search; daily prices use web fetch + token usage).
# Set in Vercel project env. Enable “web search” for the org in Anthropic Console if required.
ANTHROPIC_API_KEY=

# Model with server-tool support (Haiku may reject web tools — Sonnet is the safe default).
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Hard daily cap (USD) for estimated spend tracked in DB (tokens + web search surcharges).
# CLAUDE_DAILY_BUDGET_USD=1

# $/million input & output tokens — set to match your model on Anthropic’s pricing page.
# CLAUDE_INPUT_USD_PER_MT=3
# CLAUDE_OUTPUT_USD_PER_MT=15

# Web search surcharge per request (Anthropic list price: $10 / 1k searches = $0.01 each).
# CLAUDE_WEB_SEARCH_USD_EACH=0.01

# Enrichment: max web searches per product; budget cushion before each enrich call.
# CLAUDE_ENRICH_MAX_WEB_SEARCHES=5
# CLAUDE_ENRICH_BUDGET_RESERVE_USD=0.12

# Price refresh: products per batch, max content tokens per web_fetch page, batch reserve.
# CLAUDE_PRICE_BATCH_SIZE=4
# CLAUDE_FETCH_MAX_CONTENT_TOKENS=8000
# CLAUDE_PRICE_BATCH_RESERVE_USD=0.06

# Listing quality (Amazon / Best Buy only). Optional tuning 0.35–0.75 / 1.2–3 / 0.25–0.55.
# LISTING_PRICE_MIN_TO_MEDIAN_RATIO=0.52
# LISTING_TWO_STORE_SPREAD_RATIO=1.65
# LISTING_TWO_STORE_LOW_VS_HIGH=0.42

# Amazon Associates / partner tag for outbound Amazon links (Vercel + local). AMAZON_PARTNER_TAG is preferred.
# AMAZON_PARTNER_TAG=yoursite-20
# AMAZON_ASSOCIATES_TAG=yoursite-20

# Optional: one-time wipe via seed (migration already wipes once when applied). Remove after use.
# RESET_CATALOG_ON_SEED=1
