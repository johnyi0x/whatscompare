# Public site URL (used for metadata). Production: https://whatscompare.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Neon: pooled URL (host contains "-pooler"). Same USER:PASSWORD as DIRECT_URL.
# Do NOT add channel_binding=require — it often breaks Prisma/Node; use only sslmode + connect_timeout.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"

# Neon: direct URL (Connect → turn Connection pooling OFF). Used for prisma migrate / seed.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"

# Must match SiteStripe / Associates exactly (watch 0 vs O), e.g. whatscompar0e-20
AMAZON_PARTNER_TAG=yourstoretag-20

PAAPI_ACCESS_KEY=
PAAPI_SECRET_KEY=
PAAPI_HOST=webservices.amazon.com
PAAPI_REGION=us-east-1
PAAPI_MARKETPLACE=www.amazon.com

CRON_SECRET=

# Optional: comma/space-separated ASINs — seed creates stub Product rows for SerpApi/PA-API cron (no seed prices).
# INGEST_ASINS=B0CHLMJMWL,B08H83C89C

# One-time: set to 1 on a single deploy to wipe catalog + posts from DB, then remove. Dangerous if left on.
# RESET_CATALOG_ON_SEED=

# Optional: SerpApi Amazon Product engine (paid 3rd party). Cron only — site reads DB.
# https://serpapi.com/amazon-product-api
SERPAPI_API_KEY=
# SERPAPI_AMAZON_DOMAIN=amazon.com
# SERPAPI_LANGUAGE=en_US
# Min hours before re-fetching an ASIN (default 48). Higher = fewer API calls.
# SERPAPI_REFRESH_HOURS=48
# Max ASINs per cron run (default 5, max 25).
# SERPAPI_MAX_PER_RUN=5
# Delay between SerpApi requests in ms (default 400).
# SERPAPI_REQUEST_DELAY_MS=400
