generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Electronics SKU tracked via SerpApi Google Shopping → immersive product (multi-store prices).
model Product {
  id        String  @id @default(cuid())
  slug      String  @unique
  title     String
  imageUrl  String?
  category  String?
  brand     String?
  /// 1 = hot (frequent refresh), 2 = active, 3 = cold
  tier      Int     @default(3)

  /// google_shopping search query to discover / refresh immersive token (use cached requests when possible).
  shoppingQuery     String
  /// Prefer a shopping result whose title contains this (case-insensitive).
  shoppingMatchHint String?
  googleProductId   String?
  immersivePageToken String? @db.Text

  lastRefreshedAt DateTime?

  dealScorePercent   Decimal? @db.Decimal(6, 2)
  avgPrice90d        Decimal? @db.Decimal(12, 2)
  lowestPriceCurrent Decimal? @db.Decimal(12, 2)
  trendDirection     String?
  cheapestStoreMostOften String?
  cheapestStoreWinPct    Decimal? @db.Decimal(5, 2)
  volatilityScore    Decimal? @db.Decimal(12, 4)
  dealConfidence     String?

  currency String @default("USD")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings  ProductStoreListing[]
  snapshots PriceSnapshot[]

  @@index([brand])
  @@index([tier, lastRefreshedAt])
}

/// Latest snapshot per store (updated on each successful refresh).
model ProductStoreListing {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  store      String
  storeLabel String?
  storeUrl   String  @db.Text

  currentPrice Decimal  @db.Decimal(12, 2)
  regularPrice Decimal? @db.Decimal(12, 2)
  rating       Decimal? @db.Decimal(4, 2)
  reviewCount  Int?
  inStock      Boolean  @default(true)
  /// new | used | refurbished | unknown — from SerpApi offer text; used/refurb not shown after filter.
  listingCondition String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, store])
  @@index([productId])
}

/// Append-only price history for metrics & charts.
model PriceSnapshot {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  store        String
  price        Decimal  @db.Decimal(12, 2)
  regularPrice Decimal? @db.Decimal(12, 2)
  inStock      Boolean  @default(true)
  recordedAt   DateTime @default(now())

  @@index([productId, recordedAt])
  @@index([productId, store, recordedAt])
}

model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?   @db.Text
  body        String    @db.Text
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SyncJobLog {
  id         String    @id @default(cuid())
  job        String
  status     String
  detail     String?   @db.Text
  itemCount  Int?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
}
