generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  /// Neon: non-pooler connection for `prisma migrate` / `db seed` (see .env.example DIRECT_URL).
  directUrl = env("DIRECT_URL")
}

/// Canonical store (amazon, bestbuy, …). Phase 2: add rows per program.
model Merchant {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
  offers   Offer[]
}

/// Logical product. Amazon: externalId = ASIN. Future: UPC/GTIN field for matching across merchants.
model Product {
  id           String   @id @default(cuid())
  merchantId   String
  merchant     Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  externalId   String
  slug         String   @unique
  title        String
  brand        String?
  categoryPath String?
  description  String?  @db.Text
  /// Image URL — prefer PA-API-sourced images per Amazon policies when using their catalog.
  imageUrl     String?
  imageSource  String? // pa_api | serpapi | seed | asin_proxy | manual | none
  /// ISO 639-1 + region for Amazon marketplace (e.g. en_US).
  locale       String   @default("en_US")
  /// Last successful SerpApi `amazon_product` ingest (for TTL refresh; never set on user page views).
  serpapiSyncedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  offers         Offer[]
  priceHistory   PriceHistory[]
  postProducts   PostProduct[]

  @@unique([merchantId, externalId])
  @@index([brand])
  @@index([title])
}

/// Price snapshot / listing for a product at a merchant.
model Offer {
  id               String   @id @default(cuid())
  productId        String
  merchantId       String
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  merchant         Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  priceAmount      Decimal  @db.Decimal(12, 2)
  currency         String   @default("USD")
  listPriceAmount  Decimal? @db.Decimal(12, 2)
  dealLabel        String?
  /// Full affiliate destination when pre-built; else UI builds from ASIN + tag.
  affiliateUrl     String?
  fetchedAt        DateTime @default(now())
  source           String // pa_api | serpapi | seed | manual | cron
  availabilityNote String?
  lastSyncedAt     DateTime?

  @@index([productId])
  @@index([fetchedAt])
}

model PriceHistory {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceAmount Decimal  @db.Decimal(12, 2)
  currency    String   @default("USD")
  recordedAt  DateTime @default(now())
  source      String   @default("cron")

  @@index([productId, recordedAt])
}

/// Editorial deal roundup or single-deal writeup (blog-like, not WordPress).
model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?   @db.Text
  body        String    @db.Text
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products PostProduct[]
}

model PostProduct {
  postId    String
  productId String
  sortOrder Int     @default(0)
  blurb     String? @db.Text
  post      Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([postId, productId])
  @@index([postId])
}

model SyncJobLog {
  id         String    @id @default(cuid())
  job        String
  status     String // success | partial | skipped | error
  detail     String?   @db.Text
  itemCount  Int?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
}
