generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Electronics SKU: static fields enriched once via Claude + web search; prices refreshed on cron.
model Product {
  id        String  @id @default(cuid())
  slug      String  @unique
  title     String
  imageUrl  String?
  category  String?
  brand     String?
  /// 1 = hot, 2 = active, 3 = cold (used for ordering refreshes)
  tier      Int     @default(3)

  /// Primary research string for Claude (product + key specs).
  shoppingQuery     String
  shoppingMatchHint String?

  /// Flat specs for comparison charts (filled once at enrichment).
  specsJson            Json?
  enrichmentCompletedAt DateTime?

  /// Canonical PDP URLs (set at enrichment; price cron reads these even before listings exist).
  amazonProductUrl   String? @db.Text
  bestBuyProductUrl  String? @db.Text

  lastRefreshedAt DateTime?

  dealScorePercent   Decimal? @db.Decimal(6, 2)
  avgPrice90d        Decimal? @db.Decimal(12, 2)
  lowestPriceCurrent Decimal? @db.Decimal(12, 2)
  trendDirection     String?
  cheapestStoreMostOften String?
  cheapestStoreWinPct    Decimal? @db.Decimal(5, 2)
  volatilityScore    Decimal? @db.Decimal(12, 4)
  dealConfidence     String?

  currency String @default("USD")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings  ProductStoreListing[]
  snapshots PriceSnapshot[]

  @@index([brand])
  @@index([tier, lastRefreshedAt])
  @@index([enrichmentCompletedAt])
}

model ProductStoreListing {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  store      String
  storeLabel String?
  storeUrl   String  @db.Text

  currentPrice Decimal  @db.Decimal(12, 2)
  regularPrice Decimal? @db.Decimal(12, 2)
  rating       Decimal? @db.Decimal(4, 2)
  reviewCount  Int?
  inStock      Boolean  @default(true)
  listingCondition String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, store])
  @@index([productId])
}

model PriceSnapshot {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  store        String
  price        Decimal  @db.Decimal(12, 2)
  regularPrice Decimal? @db.Decimal(12, 2)
  inStock      Boolean  @default(true)
  recordedAt   DateTime @default(now())

  @@index([productId, recordedAt])
  @@index([productId, store, recordedAt])
}

model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?   @db.Text
  body        String    @db.Text
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SyncJobLog {
  id         String    @id @default(cuid())
  job        String
  status     String
  detail     String?   @db.Text
  itemCount  Int?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
}

/// UTC calendar day — estimated Claude spend (tokens + web searches) for budget cap.
model ClaudeDailyUsage {
  id           String   @id @default(cuid())
  day          DateTime @unique @db.Date
  estimatedUsd Decimal  @default(0) @db.Decimal(14, 6)
  updatedAt    DateTime @updatedAt
}
